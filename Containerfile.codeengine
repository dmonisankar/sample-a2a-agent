FROM registry.access.redhat.com/ubi8/python-312

# Set work directory
WORKDIR /opt/app-root

# Copy Python Project Files
COPY . /opt/app-root

USER root

# Install system build dependencies and UV package manager
RUN dnf -y update && dnf install -y gcc gcc-c++ \
    && pip install uv

# Set environment variables for uv
ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

# Assuming python and uv are installed earlier in the image
RUN python3 -m venv /opt/app-root/.venv
ENV PATH="/opt/app-root/.venv/bin:$PATH"

# Install dependencies using uv sync
RUN --mount=type=cache,target=/.cache/uv \
    uv sync --frozen --no-install-project --no-dev

# Install the project
RUN --mount=type=cache,target=/.cache/uv \
    uv sync --frozen --no-dev

# Allow non-root user access
RUN chgrp -R root /opt/app-root/ && chmod -R g+rwx /opt/app-root/

# Expose default port - Code Engine will set PORT env var
EXPOSE 8080

USER 1001

# Update CMD to use PORT environment variable (Code Engine standard)
CMD ["sh", "-c", "uv run app --host 0.0.0.0 --port ${PORT:-8080}"]
